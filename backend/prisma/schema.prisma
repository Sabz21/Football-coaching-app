generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  COACH
  PLAYER
}

enum NoteType {
  GENERAL
  SESSION_REPORT
  PERFORMANCE
  INJURY
  GOAL
  IMPORTANT
}

enum SessionType {
  INDIVIDUAL
  GROUP
  ASSESSMENT
  TRIAL
}

enum SessionStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  NO_SHOW
}

enum MatchStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  POSTPONED
  CANCELLED
}

model User {
  id               String    @id @default(cuid())
  email            String    @unique
  password         String
  firstName        String
  lastName         String
  phone            String?
  avatar           String?
  role             Role      @default(COACH)
  resetToken       String?
  resetTokenExpiry DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  coach            Coach?
}

model Coach {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  players   Player[]
  sessions  Session[]
  teams     Team[]
  matches   Match[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Player {
  id              String             @id @default(cuid())
  firstName       String
  lastName        String
  email           String?
  phone           String?
  dateOfBirth     DateTime?
  position        String?
  preferredFoot   String?
  height          Int?
  weight          Int?
  jerseyNumber    Int?
  avatar          String?
  parentName      String?
  parentEmail     String?
  parentPhone     String?
  coachId         String
  coach           Coach              @relation(fields: [coachId], references: [id], onDelete: Cascade)
  notes           PlayerNote[]
  sessions        SessionPlayer[]
  teamMemberships TeamPlayer[]
  matchStats      MatchPlayerStats[]
  manOfTheMatch   Match[]            @relation("ManOfTheMatch")
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model PlayerNote {
  id        String   @id @default(cuid())
  content   String
  type      NoteType @default(GENERAL)
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  sessionId String?
  session   Session? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model AvailabilitySlot {
  id        String   @id @default(cuid())
  dayOfWeek Int
  startTime String
  endTime   String
  isActive  Boolean  @default(true)
  coachId   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id          String        @id @default(cuid())
  title       String?
  date        DateTime
  startTime   String
  endTime     String
  location    String
  type        SessionType   @default(INDIVIDUAL)
  status      SessionStatus @default(SCHEDULED)
  objectives  String?
  notes       String?
  report      String?
  rating      Int?
  coachId     String
  coach       Coach         @relation(fields: [coachId], references: [id], onDelete: Cascade)
  players     SessionPlayer[]
  playerNotes PlayerNote[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model SessionPlayer {
  id        String   @id @default(cuid())
  attended  Boolean  @default(true)
  rating    Int?
  feedback  String?
  sessionId String
  session   Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  playerId  String
  player    Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  @@unique([sessionId, playerId])
}

model Team {
  id        String       @id @default(cuid())
  name      String
  category  String?
  season    String?
  formation String?
  coachId   String
  coach     Coach        @relation(fields: [coachId], references: [id], onDelete: Cascade)
  players   TeamPlayer[]
  matches   Match[]
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
}

model TeamPlayer {
  id           String   @id @default(cuid())
  position     String?
  jerseyNumber Int?
  isCaptain    Boolean  @default(false)
  teamId       String
  team         Team     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  playerId     String
  player       Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  @@unique([teamId, playerId])
}

model Match {
  id              String             @id @default(cuid())
  opponent        String
  date            DateTime
  time            String?
  location        String?
  isHome          Boolean            @default(true)
  competition     String?
  status          MatchStatus        @default(SCHEDULED)
  goalsFor        Int?
  goalsAgainst    Int?
  formation       String?
  preMatchNotes   String?
  postMatchNotes  String?
  coachId         String
  coach           Coach              @relation(fields: [coachId], references: [id], onDelete: Cascade)
  teamId          String
  team            Team               @relation(fields: [teamId], references: [id], onDelete: Cascade)
  manOfTheMatchId String?
  manOfTheMatch   Player?            @relation("ManOfTheMatch", fields: [manOfTheMatchId], references: [id], onDelete: SetNull)
  playerStats     MatchPlayerStats[]
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
}

model MatchPlayerStats {
  id            String   @id @default(cuid())
  minutesPlayed Int      @default(0)
  isStarter     Boolean  @default(false)
  goals         Int      @default(0)
  assists       Int      @default(0)
  yellowCards   Int      @default(0)
  redCards      Int      @default(0)
  rating        Decimal?
  matchId       String
  match         Match    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId      String
  player        Player   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  @@unique([matchId, playerId])
}